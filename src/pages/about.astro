---
import asset8 from '../assets/asset_8.svg';
import Layout from '../layouts/Layout.astro';
---

<Layout title="About / Contact | Philippa Schmitt">
	<main class="about-page">
		<section class="about-desktop">
			<div class="about-copy">
				<h1>about / contact</h1>

				<p class="about-description">
					Philippa Schmitt is a French visual artist and graphic designer
					<br />
					Born in 1995 (Mulhouse), lives in Tokyo
					<br />
					Graduated from the Fine Arts Bachelor at HEAD (Geneva) in 2022
					<br />
					and studied at ECAL (Lausanne)
				</p>

				<div class="about-links">
					<a href="https://drive.google.com/file/d/1qg2oK0UnOfwMGVXw6mzylcngTM3-DmC0/view" target="_blank" rel="noreferrer">CV</a>
					<a href="https://drive.google.com/file/d/1W8zh_I3mdPyJln3PoYyh3h2RqG8xMniW/view" target="_blank" rel="noreferrer">Available artworks</a>
					<a href="https://www.instagram.com/22fifi.archives" target="_blank" rel="noreferrer">Archive collection</a>
				</div>

				<div class="about-contact">
					<a href="mailto:Philippa.s@hotmail.com">Philippa.s@hotmail.com</a>
					<a href="https://www.instagram.com/22philippa" target="_blank" rel="noreferrer">Instagram : @22philippa</a>
				</div>
			</div>

			<img class="about-asset" src={asset8.src} alt="" aria-hidden="true" width="223" height="328" />
		</section>

		<section class="about-mobile">
			<h1>about / contact</h1>

			<img class="about-asset" src={asset8.src} alt="" aria-hidden="true" width="223" height="328" />

			<p class="about-description">
				Philippa Schmitt is a French visual artist
				<br />
				and graphic designer
				<br />
				Born in 1995 (Mulhouse),
				<br />
				lives in Tokyo
				<br />
				Graduated from the Fine Arts Bachelor
				<br />
				at HEAD (Geneva) in 2022
				<br />
				and studied at ECAL (Lausanne)
			</p>

			<div class="about-links">
				<a href="https://drive.google.com/file/d/1qg2oK0UnOfwMGVXw6mzylcngTM3-DmC0/view" target="_blank" rel="noreferrer">CV</a>
				<a href="https://drive.google.com/file/d/1r3vQ3Y8YgX-zt_t18Da80IGlktEtlBod/view?usp=drive_link" target="_blank" rel="noreferrer">Available artworks</a>
				<a href="https://www.instagram.com/22fifi.archives" target="_blank" rel="noreferrer">Archive collection</a>
			</div>

			<div class="about-contact">
				<a href="mailto:Philippa.s@hotmail.com">Philippa.s@hotmail.com</a>
				<a href="https://www.instagram.com/22philippa" target="_blank" rel="noreferrer">Instagram : @22philippa</a>
			</div>
		</section>
	</main>
</Layout>

<style>
	.about-page {
		min-height: 100vh;
		background: #fff;
		color: #111;
		font-family: Arial, Helvetica, sans-serif;
	}

	.about-desktop,
	.about-mobile {
		box-sizing: border-box;
	}

	.about-desktop {
		position: relative;
		min-height: 100vh;
		padding: 46px 48px;
	}

	.about-copy {
		max-width: 600px;
	}

	h1 {
		margin: 0;
		font-size: 31px;
		font-weight: 400;
		line-height: 1.08;
	}

	.about-description,
	.about-links,
	.about-contact,
	.about-links a,
	.about-contact a {
		font-size: 17px;
		font-weight: 400;
		line-height: 1.1;
	}

	.about-description {
		margin: 54px 0 0;
	}

	.about-links,
	.about-contact {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.about-links {
		margin-top: 22px;
		gap: 2px;
	}

	.about-contact {
		margin-top: 26px;
		gap: 2px;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	a:hover,
	a:focus-visible {
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.about-asset {
		display: block;
		width: 223px;
		height: 328px;
		object-fit: contain;
	}

	.about-desktop .about-asset {
		position: absolute;
		left: 44px;
		top: 392px;
	}

	.about-mobile {
		display: none;
	}

	@media (max-width: 900px) {
		.about-desktop {
			display: none;
		}

		.about-mobile {
			min-height: 100dvh;
			padding: 58px 20px 44px;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			text-align: center;
		}

		h1 {
			font-size: 23px;
		}

		.about-mobile .about-asset {
			margin-top: 42px;
			max-width: min(223px, 62vw);
			width: 223px;
			height: 328px;
		}

		.about-description,
		.about-links,
		.about-contact,
		.about-links a,
		.about-contact a {
			font-size: 14px;
			line-height: 1.08;
		}

		.about-description {
			margin: 28px 0 0;
		}

		.about-links {
			margin-top: 30px;
			align-items: center;
		}

		.about-contact {
			margin-top: 30px;
			align-items: center;
		}
	}

	@media (max-width: 420px) {
		.about-mobile {
			padding-left: 16px;
			padding-right: 16px;
		}

		.about-mobile .about-asset {
			max-width: min(223px, 66vw);
			height: auto;
		}
	}

	@media (max-height: 760px) and (max-width: 900px) {
		.about-mobile {
			padding-top: 34px;
			padding-bottom: 28px;
			gap: 0;
			justify-content: flex-start;
		}

		.about-mobile .about-asset {
			margin-top: 26px;
			max-width: min(200px, 54vw);
		}

		.about-description {
			margin-top: 20px;
		}

		.about-links,
		.about-contact {
			margin-top: 22px;
		}
	}
</style>
