---
import { floatingAssets, navLinks } from '../data/floatingAssets';

const mobileAnchorAsset = floatingAssets.find((asset) => asset.className === 'asset-6');
const floatingSceneAssets = floatingAssets.filter((asset) => asset.className !== 'asset-6');
---

<section class="landing">
	<div class="copy">
		<h1>Philippa Schmitt</h1>
		<nav aria-label="Main navigation">
			<ul>
				{
					navLinks.map((link) => (
						<li>
							<a
								href={link.href}
								target={link.href.startsWith('http') ? '_blank' : undefined}
								rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>
	</div>

	<div class="floating-assets" aria-hidden="true">
		{
			floatingSceneAssets.map((asset) => (
				<div
					class={`floating-asset ${asset.className}`}
					style={asset.style}
					data-repel-strength={asset.dataAttributes.strength}
					data-repel-radius={asset.dataAttributes.radius}
				>
					<div class="floating-asset__inner">
						<img
							src={asset.src}
							alt={asset.alt}
							width={asset.dimensions.width}
							height={asset.dimensions.height}
						/>
					</div>
				</div>
			))
		}
	</div>

	{
		mobileAnchorAsset && (
			<div class="mobile-anchor-asset" aria-hidden="true">
				<img
					src={mobileAnchorAsset.src}
					alt=""
					width={mobileAnchorAsset.dimensions.width}
					height={mobileAnchorAsset.dimensions.height}
				/>
			</div>
		)
	}
</section>

<style>
	:root {
		font-family: Arial, Helvetica, sans-serif;
	}

	.landing {
		position: relative;
		min-height: 100vh;
		background: #fff;
		overflow: hidden;
		isolation: isolate;
		padding: 34px 42px;
	}

	.copy {
		position: relative;
		z-index: 20;
		display: flex;
		flex-direction: column;
		gap: 18px;
		width: min(340px, 100%);
	}

	h1 {
		margin: 0;
		font-family: Arial, Helvetica, sans-serif;
		font-size: 39px;
		font-weight: 400;
		line-height: 1.08;
		color: #111;
	}

	nav ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	nav a {
		font-family: Arial, Helvetica, sans-serif;
		font-size: 18px;
		font-weight: 400;
		line-height: 1.25;
		color: #222;
		text-decoration: none;
	}

	nav a:hover,
	nav a:focus-visible {
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.floating-assets {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 1;
		overflow: hidden;
	}

	.mobile-anchor-asset {
		display: none;
	}

	.floating-asset {
		position: absolute;
		top: var(--desktop-top, auto);
		right: var(--desktop-right, auto);
		bottom: var(--desktop-bottom, auto);
		left: var(--desktop-left, auto);
		width: var(--asset-width, auto);
		height: var(--asset-height, auto);
		z-index: var(--asset-depth, 1);
		animation: drift var(--float-duration) ease-in-out infinite;
		animation-delay: var(--float-delay);
		will-change: transform;
	}

	.floating-asset__inner {
		width: 100%;
		height: 100%;
		transform: translate3d(var(--pointer-x, 0px), var(--pointer-y, 0px), 0)
			rotate(var(--pointer-rotate, 0deg));
		transform-origin: center;
		will-change: transform;
	}

	.floating-asset img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	@keyframes drift {
		0%,
		100% {
			transform: translate3d(0, 0, 0) rotate(0deg);
		}

		20% {
			transform: translate3d(var(--drift-x-1, 0px), var(--drift-y-1, 0px), 0)
				rotate(calc(var(--float-tilt) * 0.55));
		}

		45% {
			transform: translate3d(var(--drift-x-2, 0px), var(--drift-y-2, 0px), 0)
				rotate(var(--float-tilt));
		}

		70% {
			transform: translate3d(var(--drift-x-3, 0px), var(--drift-y-3, 0px), 0)
				rotate(calc(var(--float-tilt) * -0.35));
		}

		88% {
			transform: translate3d(var(--drift-x-4, 0px), var(--drift-y-4, 0px), 0)
				rotate(calc(var(--float-tilt) * -0.5));
		}
	}

	@keyframes drift-mobile {
		0%,
		100% {
			transform: translate3d(0, 0, 0) rotate(0deg);
		}

		20% {
			transform: translate3d(
					calc(var(--drift-x-1, 0px) * var(--mobile-drift-scale, 0.28)),
					calc(var(--drift-y-1, 0px) * var(--mobile-drift-scale, 0.28)),
					0
				)
				rotate(calc(var(--float-tilt) * 0.34));
		}

		45% {
			transform: translate3d(
					calc(var(--drift-x-2, 0px) * var(--mobile-drift-scale, 0.28)),
					calc(var(--drift-y-2, 0px) * var(--mobile-drift-scale, 0.28)),
					0
				)
				rotate(calc(var(--float-tilt) * 0.62));
		}

		70% {
			transform: translate3d(
					calc(var(--drift-x-3, 0px) * var(--mobile-drift-scale, 0.28)),
					calc(var(--drift-y-3, 0px) * var(--mobile-drift-scale, 0.28)),
					0
				)
				rotate(calc(var(--float-tilt) * -0.24));
		}

		88% {
			transform: translate3d(
					calc(var(--drift-x-4, 0px) * var(--mobile-drift-scale, 0.28)),
					calc(var(--drift-y-4, 0px) * var(--mobile-drift-scale, 0.28)),
					0
				)
				rotate(calc(var(--float-tilt) * -0.3));
		}
	}

	@media (max-width: 900px) {
		.landing {
			min-height: 100dvh;
			padding: 0 0 320px;
		}

		.copy {
			position: absolute;
			top: 42%;
			left: 50%;
			transform: translate(-50%, -50%);
			width: min(320px, calc(100vw - 36px));
			max-width: 320px;
			align-items: center;
			gap: 24px;
			text-align: center;
		}

		h1 {
			font-size: 30px;
			line-height: 1.05;
		}

		nav ul {
			gap: 22px;
		}

		nav a {
			font-size: 23px;
		}

		.asset-1,
		.asset-2 {
			display: none;
		}

		.floating-asset {
			position: fixed;
			top: var(--mobile-top, auto);
			right: var(--mobile-right, auto);
			bottom: var(--mobile-bottom, auto);
			left: var(--mobile-left, auto);
			width: var(--mobile-asset-width, var(--asset-width, auto));
			height: var(--mobile-asset-height, var(--asset-height, auto));
			animation-name: drift-mobile;
			animation-duration: calc(var(--float-duration) * 1.08);
		}

		.mobile-anchor-asset {
			display: block;
			position: absolute;
			top: calc(42% + 168px);
			left: 50%;
			z-index: 2;
			transform: translateX(-50%);
		}

		.mobile-anchor-asset img {
			display: block;
			width: 208px;
			height: 302px;
			object-fit: contain;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.floating-asset__inner {
			transform: none;
		}
	}
</style>

<script>
	import { initFloatingAssets } from '../scripts/floatingAssets';

	initFloatingAssets();
</script>
