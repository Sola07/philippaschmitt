---
import { landingAssets, navLinks } from '../data/floatingAssets';
---

<section class="landing" data-landing-root>
	<div class="copy">
		<h1>Philippa Schmitt</h1>
		<nav aria-label="Main navigation">
			<ul>
				{
					navLinks.map((link) => (
						<li>
							<a
								href={link.href}
								target={link.href.startsWith('http') ? '_blank' : undefined}
								rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>
	</div>

	<div class="asset-scene" aria-hidden="true">
		{
			landingAssets.map((asset) => {
				const mobileDimensions = asset.mobileDimensions ?? asset.dimensions;
				return (
					<div
						class={`landing-asset ${asset.className}`}
						data-width={mobileDimensions.width}
						data-height={mobileDimensions.height}
						data-width-desktop={asset.dimensions.width}
						data-height-desktop={asset.dimensions.height}
						data-hide-on-mobile={asset.hideOnMobile ? 'true' : 'false'}
						style={`--asset-depth: ${asset.depth}; --asset-width: ${asset.dimensions.width}px; --asset-height: ${asset.dimensions.height}px; --mobile-asset-width: ${mobileDimensions.width}px; --mobile-asset-height: ${mobileDimensions.height}px;`}
					>
						<img
							src={asset.src}
							alt={asset.alt}
							width={asset.dimensions.width}
							height={asset.dimensions.height}
						/>
					</div>
				);
			})
		}
	</div>
</section>

<style>
	:root {
		font-family: Arial, Helvetica, sans-serif;
	}

	.landing {
		position: relative;
		min-height: 100vh;
		background: #fff;
		overflow: hidden;
		isolation: isolate;
		padding: 34px 42px;
	}

	.copy {
		position: relative;
		z-index: 20;
		display: flex;
		flex-direction: column;
		gap: 18px;
		width: min(340px, 100%);
	}

	h1 {
		margin: 0;
		font-size: 39px;
		font-weight: 400;
		line-height: 1.08;
		color: #111;
	}

	nav ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	nav a {
		font-size: 18px;
		font-weight: 400;
		line-height: 1.25;
		color: #222;
		text-decoration: none;
	}

	nav a:hover,
	nav a:focus-visible {
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.asset-scene {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 1;
	}

	.landing-asset {
		position: absolute;
		width: var(--asset-width);
		height: var(--asset-height);
		z-index: var(--asset-depth, 1);
		opacity: 0.98;
		pointer-events: auto;
		touch-action: none;
		cursor: grab;
		user-select: none;
	}

	.landing-asset img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
		-webkit-user-drag: none;
		user-select: none;
		pointer-events: none;
	}

	.landing-asset.is-dragging {
		cursor: grabbing;
	}

	@media (max-width: 900px) {
		.landing {
			min-height: 100dvh;
			padding: 0;
		}

		.copy {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
			width: min(320px, calc(100vw - 36px));
			max-width: 320px;
			align-items: center;
			gap: 26px;
			text-align: center;
		}

		h1 {
			font-size: 30px;
			line-height: 1.05;
		}

		nav ul {
			gap: 24px;
		}

		nav a {
			font-size: 23px;
		}

		.landing-asset {
			width: var(--mobile-asset-width);
			height: var(--mobile-asset-height);
		}
	}
</style>

<script>
	import { initLandingAssetLayout } from '../scripts/landingAssetLayout';

	initLandingAssetLayout();
</script>
